<!DOCTYPE html>
<html lang="es" class="Vigia-APP">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Vigía Plagas - Cotizador Profesional</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        :root {
            --azul-pro: #001a33; 
            --azul-medio: #004080;
            --azul-claro: #0072ff;
            --verde-3d: #28a745;
            --verde-sombra: #1e7e34;
            --mp-3d: #009ee3;
            --mp-sombra: #007bbd;
            --fondo: #f0f4f8;
            --gris-pdf: #495057;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body, html { margin: 0; padding: 0; background: var(--fondo); font-family: 'Segoe UI', Roboto, sans-serif; }

        header {
            background: linear-gradient(180deg, var(--azul-pro) 0%, var(--azul-medio) 60%, var(--azul-claro) 100%);
            color: white; padding: 40px 20px 10px; text-align: center; position: relative; z-index: 1;
        }

        .btn-share {
            position: absolute; top: 15px; right: 15px;
            background: rgba(255,255,255,0.2); border: none;
            border-radius: 50%; padding: 10px; color: white; cursor: pointer;
        }

        .logo-escudo {
            width: 75px; height: 75px; background: white; border-radius: 50%;
            margin: 0 auto 12px; display: flex; align-items: center; justify-content: center;
            font-size: 42px; box-shadow: 0 6px 12px rgba(0,0,0,0.4); 
            border: 3px solid #ffd700;
        }

        h1 { margin: 0; font-size: 26px; font-weight: 800; letter-spacing: 1px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
        header p { margin: 5px 0 0; opacity: 0.9; font-size: 14px; font-weight: 300; }

        .wave-container { line-height: 0; fill: var(--azul-claro); background-color: var(--fondo); }
        .content { padding: 0 20px 40px; position: relative; z-index: 2; margin-top: 5px; }

        /* CAMPOS */
        .campo-3d {
            background: white; border-radius: 16px; padding: 4px 15px;
            margin-bottom: 14px; display: flex; align-items: center;
            border: 1px solid #d1d9e6; box-shadow: 4px 4px 8px #d1d9e6, -4px -4px 8px #ffffff;
        }

        .icon { width: 35px; font-size: 20px; }
        select, input {
            flex: 1; border: none; background: transparent; padding: 14px 5px;
            font-size: 16px; outline: none; color: #333; font-weight: 500;
        }

        .nota-informativa {
            font-size: 12px; color: #d63031; margin: -10px 0 15px 10px; font-weight: bold; display: none;
        }

        /* PROTOCOLO */
        .protocolo-box {
            background: #fffdf5; border-left: 6px solid #ffcc00;
            border-radius: 12px; padding: 18px; margin: 25px 0;
            font-size: 13px; color: #7a5f00; box-shadow: 2px 4px 10px rgba(0,0,0,0.05);
            line-height: 1.5;
        }

        /* BOTÓN ACEPTAR */
        .btn-check-3d {
            background: linear-gradient(180deg, #5fb2ff, #007bff);
            color: white; padding: 20px; border-radius: 18px;
            text-align: center; font-weight: 900; cursor: pointer;
            box-shadow: 0 8px 0 #0056b3; margin-bottom: 30px;
            transition: 0.1s; text-transform: uppercase; letter-spacing: 1px;
        }
        .btn-check-3d:active { transform: translateY(4px); box-shadow: 0 4px 0 #0056b3; }
        .active { background: var(--verde-3d) !important; box-shadow: 0 8px 0 var(--verde-sombra) !important; }

        /* RESULTADOS */
        #resultado { display: none; text-align: center; animation: fadeInUp 0.5s ease; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        .precio-grande { font-size: 48px; font-weight: 900; color: var(--azul-pro); margin: 10px 0 25px; }

        .flex-btns { display: flex; flex-direction: column; gap: 12px; }
        .action-btn {
            padding: 16px; border-radius: 16px; text-decoration: none;
            color: white; font-weight: bold; font-size: 15px; text-align: center;
            box-shadow: 0 6px 0 rgba(0,0,0,0.2); transition: 0.1s;
        }
        .action-btn:active { transform: translateY(3px); box-shadow: 0 3px 0 rgba(0,0,0,0.2); }
        
        .btn-ws { background: var(--verde-3d); box-shadow: 0 6px 0 var(--verde-sombra); }
        .btn-mp { background: var(--mp-3d); box-shadow: 0 6px 0 var(--mp-sombra); }
        .btn-pdf { background: var(--gris-pdf); box-shadow: 0 6px 0 #212529; }
        
        .row-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    </style>
</head>
<body>

<header>
    <button class="btn-share" onclick="compartirApp()">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
    </button>
    <div class="logo-escudo">🛡️</div>
    <h1>VIGÍA PLAGAS</h1>
    <p>Control Profesional de Plagas</p>
</header>

<div class="wave-container">
    <svg viewBox="0 0 500 100" preserveAspectRatio="none" style="height: 60px; width: 100%;">
        <path d="M0,0 C150,120 350,0 500,100 L500,00 L0,0 Z" style="stroke: none;"></path>
    </svg>
</div>

<div class="content">
    
    <div class="campo-3d">
        <div class="icon">👤</div>
        <input type="text" id="nombreCliente" placeholder="Nombre completo" oninput="recalcular()">
    </div>

    <div class="campo-3d">
        <div class="icon">📍</div>
        <input type="text" id="zona" placeholder="Barrio / Ubicación" oninput="recalcular()">
    </div>

    <div class="campo-3d">
        <div class="icon">🛠️</div>
        <select id="tipoServicio" onchange="toggleServicio()">
            <option value="completo">Servicio Interior o Completo</option>
            <option value="exterior">Solo por fuera de la vivienda - $50.000</option>
        </select>
    </div>
    <div id="notaExterior" class="nota-informativa">
        * El valor puede variar según el tamaño de la vivienda y el técnico le informará en el lugar.
    </div>

    <div id="bloqueVivienda">
        <div class="campo-3d">
            <div class="icon">🏠</div>
            <select id="vivienda" onchange="toggleInputs()">
                <option value="50000">Monoambiente - $50.000</option>
                <option value="60000">Departamento - $60.000</option>
                <option value="70000">Casa - $70.000</option>
            </select>
        </div>

        <div class="campo-3d" id="box-amb" style="display:none;">
            <div class="icon">🛌</div>
            <select id="ambientes" onchange="recalcular()">
                <option value="0">Sin Dormitorios Extra</option>
                <option value="10000">+1 Dormitorio Extra (+$10.000)</option>
                <option value="20000">+2 Dormitorios Extra (+$20.000)</option>
            </select>
        </div>
    </div>

    <div class="campo-3d">
        <div class="icon">🐜</div>
        <select id="plaga" onchange="recalcular()">
            <option value="0">Cucarachas/Hormigas/Grillos- (Base)</option>
            <option value="10000">Alacranes - (+$10.000)</option>
            <option value="30000">Cucaracha Alemana/Arañas - (+$30.000)</option>
            <option value="50000">Pulgas/Garrapatas - (+$50.000)</option>
        </select>
    </div>

    <div class="campo-3d">
        <div class="icon">📅</div>
        <input type="datetime-local" id="fecha" onchange="recalcular()">
    </div>

    <div class="protocolo-box" id="protocoloTexto">
        <b>⚠️ PROTOCOLO DE SEGURIDAD:</b><br>
        • Desocupar el lugar 4 a 6 horas.<br>
        • Guardar comida, pan y vajilla.<br>
        • Mascotas fuera del área de servicio.<br>
        • Quitar sabanas y colchas, dejar colchones solos.
    </div>

    <div class="btn-check-3d" id="btnCheck" onclick="toggleAceptacion()">
        ACEPTAR PROTOCOLO
    </div>

    <div id="resultado">
        <small style="color:#666; font-weight:bold; letter-spacing:1px;">PRESUPUESTO ESTIMADO:</small>
        <div class="precio-grande" id="total">$0</div>
        
        <div class="flex-btns">
            <a href="#" id="btnWS" class="action-btn btn-ws" target="_blank">ENVIAR A WHATSAPP</a>
            
            <div class="row-btns">
                <a href="#" onclick="generarPDF()" class="action-btn btn-pdf">DESCARGAR PDF</a>
                <a href="https://mpago.la/1q3rv2n" class="action-btn btn-mp" target="_blank">PAGAR SEÑA</a>
            </div>
        </div>
        <p style="font-size: 11px; color: #999; margin-top: 20px; font-weight: bold;">SEÑA PARA RESERVA: $1.000</p>
    </div>
</div>

<script>
    let aceptado = false;

    function toggleServicio() {
        const tipo = document.getElementById('tipoServicio').value;
        const bloqueVivienda = document.getElementById('bloqueVivienda');
        const nota = document.getElementById('notaExterior');
        
        if (tipo === 'exterior') {
            bloqueVivienda.style.display = 'none';
            nota.style.display = 'block';
        } else {
            bloqueVivienda.style.display = 'block';
            nota.style.display = 'none';
        }
        recalcular();
    }

    function toggleInputs() {
        const v = document.getElementById('vivienda').value;
        document.getElementById('box-amb').style.display = (v === "50000") ? "none" : "flex";
        recalcular();
    }

    function toggleAceptacion() {
        aceptado = !aceptado;
        const btn = document.getElementById('btnCheck');
        const res = document.getElementById('resultado');
        if(aceptado) {
            btn.classList.add('active');
            btn.innerText = "✓ PROTOCOLO ACEPTADO";
            res.style.display = 'block';
            recalcular();
            res.scrollIntoView({ behavior: 'smooth' });
        } else {
            btn.classList.remove('active');
            btn.innerText = "ACEPTAR PROTOCOLO";
            res.style.display = 'none';
        }
    }

    function recalcular() {
        if(!aceptado) return;
        
        const tipoServicio = document.getElementById('tipoServicio').value;
        let base = 0;
        let extraA = 0;
        
        if (tipoServicio === 'exterior') {
            base = 50000;
        } else {
            base = parseInt(document.getElementById('vivienda').value) || 0;
            extraA = parseInt(document.getElementById('ambientes').value) || 0;
        }

        const plaga = parseInt(document.getElementById('plaga').value) || 0;
        const total = base + extraA + plaga;
        
        document.getElementById('total').innerText = "$" + total.toLocaleString('es-AR');

        const nombre = document.getElementById('nombreCliente').value || "Cliente";
        const zona = document.getElementById('zona').value || "No especificada";
        const fecha = document.getElementById('fecha').value.replace('T', ' ') || "A convenir";
        const plagaTxt = document.getElementById('plaga').selectedOptions[0].text;

        const msg = `🛡️ *VIGÍA PLAGAS - NUEVO PEDIDO*%0A👤 *Cliente:* ${nombre}%0A📍 *Zona:* ${zona}%0A🛠️ *Servicio:* ${document.getElementById('tipoServicio').selectedOptions[0].text}%0A🐜 *Plaga:* ${plagaTxt}%0A📅 *Fecha:* ${fecha}%0A💰 *TOTAL:* $${total.toLocaleString('es-AR')}%0A%0A✅ *Protocolo Aceptado*`;
        document.getElementById('btnWS').href = `https://wa.me/5493518087250?text=${msg}`;
    }

    function generarPDF() {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();
        
        const nombre = document.getElementById('nombreCliente').value || "---";
        const zona = document.getElementById('zona').value || "---";
        const total = document.getElementById('total').innerText;
        const fecha = document.getElementById('fecha').value.replace('T', ' ') || "A convenir";
        const servicio = document.getElementById('tipoServicio').selectedOptions[0].text;
        const plaga = document.getElementById('plaga').selectedOptions[0].text;

        // Estilos PDF - Encabezado
        doc.setFillColor(0, 26, 51);
        doc.rect(0, 0, 210, 45, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(24);
        doc.setFont(undefined, 'bold');
        doc.text("VIGÍA PLAGAS", 20, 22);
        doc.setFontSize(11);
        doc.setFont(undefined, 'normal');
        doc.text("Control Profesional de Plagas | Córdoba, Argentina", 20, 32);
        doc.text("Tel: 3518087250", 150, 32);
        
        // Cuerpo del Presupuesto
        doc.setTextColor(0, 0, 0);
        doc.setFontSize(14);
        doc.setFont(undefined, 'bold');
        doc.text("PRESUPUESTO DE SERVICIO", 20, 60);
        
        doc.setFontSize(11);
        doc.text("DATOS DEL CLIENTE Y UBICACIÓN:", 20, 75);
        doc.setFont(undefined, 'normal');
        doc.text(`Nombre: ${nombre}`, 25, 82);
        doc.text(`Zona/Barrio: ${zona}`, 25, 89);
        doc.text(`Fecha solicitada: ${fecha}`, 25, 96);
        
        doc.line(20, 102, 190, 102);

        doc.setFont(undefined, 'bold');
        doc.text("DETALLES DEL SERVICIO:", 20, 112);
        doc.setFont(undefined, 'normal');
        doc.text(`Tipo de Servicio: ${servicio}`, 25, 120);
        doc.text(`Plaga a tratar: ${plaga}`, 25, 128);
        
        // Precio destacado
        doc.setFillColor(240, 244, 248);
        doc.rect(20, 138, 170, 15, 'F');
        doc.setFontSize(14);
        doc.setFont(undefined, 'bold');
        doc.text(`TOTAL ESTIMADO: ${total}`, 25, 148);

        // Protocolos
        doc.setFontSize(11);
        doc.text("⚠️ PROTOCOLOS DE SEGURIDAD OBLIGATORIOS:", 20, 168);
        doc.setFontSize(10);
        doc.setFont(undefined, 'normal');
        const lista = [
            "- Desocupar el inmueble de 4 a 6 horas luego del servicio.",
            "- Guardar alimentos, panificados y vajilla en recipientes hermeticos.",
            "- Las mascotas deben permanecer fuera del area tratada.",
            "- Retirar ropa de cama y dejar los colchones despejados."
        ];
        doc.text(lista, 25, 178);

        // Pie de página
        doc.setFontSize(9);
        doc.setFont(undefined, 'italic');
        doc.setTextColor(100, 100, 100);
        doc.text("* En caso de fumigaciones exteriores, el valor puede variar según m2.", 20, 220);
        doc.text("* Presupuesto válido por 10 días.", 20, 226);

        doc.save(`Presupuesto_VigiaPlagas_${nombre}.pdf`);
    }

    function compartirApp() {
        if (navigator.share) {
            navigator.share({ title: 'Vigía Plagas', text: 'Cotizá tu desinfección online 🛡️', url: window.location.href });
        }
    }
</script>
</body>
</html>
